{
  "name": "heinu1-wechat-bot",
  "version": "0.1.0",
  "description": "WeChat iLink → Claude Code bridge for home laptop",
  "type": "commonjs",
  "scripts": {
    "start":   "tsx src/main.ts",
    "relogin": "tsx src/main.ts --relogin",
